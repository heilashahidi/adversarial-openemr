# Target System
TARGET_BASE_URL=https://openemr.146-190-75-148.sslip.io

# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LangSmith — observability for every LLM call (optional; tracing is off if unset)
# Get a key from https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-key-here
LANGCHAIN_PROJECT=adversarial-openemr

# Model overrides (optional — defaults in config.py)
# RED_TEAM_MODEL=mistralai/mistral-7b-instruct
# MUTATION_MODEL=meta-llama/llama-3.1-8b-instruct
# JUDGE_MODEL=anthropic/claude-3.5-haiku
# ORCHESTRATOR_MODEL=meta-llama/llama-3.1-8b-instruct
# DOCUMENTATION_MODEL=mistralai/mistral-7b-instruct
